ENV['RCT_NEW_ARCH_ENABLED'] = '1'

# Resolve react_native_pods.rb with node to allow for hoisting
require Pod::Executable.execute_command('node', ['-p',
  'require.resolve(
    "react-native/scripts/react_native_pods.rb",
    {paths: [process.argv[1]]},
  )', __dir__]).strip

platform :ios, min_ios_version_supported
prepare_react_native_project!

linkage = ENV['USE_FRAMEWORKS']
if linkage != nil
  Pod::UI.puts "Configuring Pod with #{linkage}ally linked Frameworks".green
  use_frameworks! :linkage => linkage.to_sym
end

# Disable prebuilt React Native dependencies to avoid xcframework linkage issues
ENV['RCT_USE_RN_DEP'] = '0'

target 'PushengageReactNativeExample' do
  config = use_native_modules!

  use_react_native!(
    :path => config[:reactNativePath],
    # An absolute path to your application root.
    :app_path => "#{Pod::Config.instance.installation_root}/.."
  )

  target 'PushengageReactNativeExampleTests' do
    inherit! :complete
    # Pods for testing
  end


  pre_install do |installer|
    system("cd ../../ && npx bob build --target codegen")
  end

  post_install do |installer|
    # https://github.com/facebook/react-native/blob/main/packages/react-native/scripts/react_native_pods.rb#L197-L202
    react_native_post_install(
      installer,
      config[:reactNativePath],
      :mac_catalyst_enabled => false,
      # :ccache_enabled => true
    )
    
    
      installer.pods_project.targets.each do |target|
        target.build_configurations.each do |config|
          # Special handling only for PushEngage SDK in app extensions
          if target.name.include?('PushEngage')
            config.build_settings['APPLICATION_EXTENSION_API_ONLY'] = 'No'
            config.build_settings['CLANG_ALLOW_NON_MODULAR_INCLUDES_IN_FRAMEWORK_MODULES'] = 'YES'
          end

          # Fix duplicate symbols by excluding codegen files from pushengage-react-native
          if target.name == 'pushengage-react-native'
            target.source_build_phase.files.to_a.each do |build_file|
              if build_file.file_ref.path.include?('generated/') || 
                 build_file.file_ref.path.include?('RCTAppDependencyProvider') ||
                 build_file.file_ref.path.include?('RCTModuleProviders') ||
                 build_file.file_ref.path.include?('RCTThirdPartyComponentsProvider') ||
                 build_file.file_ref.path.include?('RCTUnstableModulesRequiringMainQueueSetupProvider') ||
                 build_file.file_ref.path.include?('RCTModulesConformingToProtocolsProvider')
                target.source_build_phase.remove_file_reference(build_file.file_ref)
              end
            end
          end
        end
      end
      # Persist glog module fix so future pod installs don't reintroduce the issue
      require 'fileutils'
      glog_modulemap_path = File.join(Pod::Config.instance.installation_root.to_s, 'Pods', 'Headers', 'Public', 'glog', 'glog.modulemap')
      begin
        FileUtils.mkdir_p(File.dirname(glog_modulemap_path))
        File.write(glog_modulemap_path, "module glog {\n  header \"glog/logging.h\"\n  export *\n}\n")
        Pod::UI.puts "Applied header-only glog.modulemap to avoid namespace import issues"
      rescue => e
        Pod::UI.warn "Failed to write glog.modulemap: #{e}"
      end
      
      
      
      # Add build phase to main app target to ensure Hermes dSYM is generated into archive (UUID match)
      main_target = installer.pods_project.targets.find { |target| target.name == 'PushengageReactNativeExample' }
      if main_target.nil?
        # If we can't find the main target in Pods project, add to the main app project instead
        installer.aggregate_targets.each do |aggregate_target|
          aggregate_target.user_project.targets.each do |target|
            if target.name == 'PushengageReactNativeExample'
              build_phase = target.new_shell_script_build_phase('Copy Hermes dSYM to Archive')
              build_phase.shell_script = <<~SCRIPT
                set -e
                
                # Only run during archive builds
                if [ "$ACTION" = "install" ] && [ "$CONFIGURATION" = "Release" ]; then
                  echo "🔄 Ensuring Hermes dSYM is included in archive..."
                  APP_PATH="${TARGET_BUILD_DIR}/${WRAPPER_NAME}"
                  HERMES_BIN="${APP_PATH}/Frameworks/hermes.framework/hermes"
                  ARCHIVE_DSYM_DIR="${DWARF_DSYM_FOLDER_PATH}"
                  
                  if [ -f "$HERMES_BIN" ] && [ -n "$ARCHIVE_DSYM_DIR" ]; then
                    echo "📍 Found Hermes binary at: $HERMES_BIN"
                    mkdir -p "$ARCHIVE_DSYM_DIR"
                    echo "🔧 Generating dSYM into archive with dsymutil..."
                    dsymutil "$HERMES_BIN" -o "$ARCHIVE_DSYM_DIR/hermes.framework.dSYM" || { echo "❌ dsymutil failed"; exit 1; }
                    if [ -f "$ARCHIVE_DSYM_DIR/hermes.framework.dSYM/Contents/Resources/DWARF/hermes" ]; then
                      echo "✅ Hermes dSYM generated in archive"
                      if command -v dwarfdump >/dev/null 2>&1; then
                        echo "🔍 App Hermes UUID(s):"; dwarfdump --uuid "$HERMES_BIN" || true
                        echo "🔍 dSYM Hermes UUID(s):"; dwarfdump --uuid "$ARCHIVE_DSYM_DIR/hermes.framework.dSYM/Contents/Resources/DWARF/hermes" || true
                      fi
                    else
                      echo "❌ Failed to generate Hermes dSYM in archive"
                    fi
                  else
                    echo "⚠️  Hermes binary not found inside app or archive dSYM dir missing"
                  fi
                else
                  echo "ℹ️  Skipping dSYM archive copy (not an archive build)"
                fi
              SCRIPT
              break
            end
          end
        end
      end
  end
end

target 'NotificationServiceExtension' do
  pod 'PushEngage', '0.0.6'
end

target 'NotificationContentExtension' do
  pod 'PushEngage', '0.0.6'
end