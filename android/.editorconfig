# EditorConfig for Android Kotlin files
root = true

[*.{kt,kts}]
charset = utf-8
end_of_line = lf
indent_size = 4
indent_style = space
insert_final_newline = true
max_line_length = 120
trim_trailing_whitespace = true

[*.gradle]
indent_size = 4
indent_style = space

[*.{xml,json}]
indent_size = 2
indent_style = space

