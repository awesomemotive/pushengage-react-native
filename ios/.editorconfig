# EditorConfig for iOS Swift files
root = true

[*.swift]
charset = utf-8
end_of_line = lf
indent_size = 4
indent_style = space
insert_final_newline = true
max_line_length = 120
trim_trailing_whitespace = true

[*.{h,m,mm}]
charset = utf-8
end_of_line = lf
indent_size = 4
indent_style = space
insert_final_newline = true
max_line_length = 120
trim_trailing_whitespace = true

[*.{plist,xcconfig,strings}]
indent_size = 2
indent_style = space

[*.{json,xcscheme}]
indent_size = 2
indent_style = space

